<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- All domains require HTTPS — no cleartext exceptions. -->
    <!-- Content updates use signed HTTPS catalog via ContentUpdateWorker. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
